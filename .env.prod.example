APP_NAME=app-clinica
APP_ENV=production
TZ=America/Argentina/Buenos_Aires
# Zona usada para validar horarios de consultorio vs reservas (ISO IANA). Suele coincidir con TZ.
BUSINESS_TIMEZONE=America/Argentina/Buenos_Aires

GHCR_OWNER=lelion13
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest
WEB_HOST=clinica.lionapp.cloud

DATABASE_URL=postgresql+psycopg://app_clinica:<DB_PASSWORD>@db:5432/app_clinica
POSTGRES_DB=app_clinica
POSTGRES_USER=app_clinica
POSTGRES_PASSWORD=<DB_PASSWORD>
POSTGRES_PORT=5432

JWT_SECRET=<JWT_SUPER_SECRETO_LARGO>
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
BCRYPT_ROUNDS=12

COOKIE_SECURE=true
COOKIE_SAMESITE=lax
# Mismo dominio (nginx del frontend proxea `/api` al backend): usar el origin publico del front.
# Acepta CSV o JSON (lista). Ejemplos:
# CORS_ORIGINS=https://clinica.lionapp.cloud
# CORS_ORIGINS=https://clinica.lionapp.cloud,https://www.tudominio.com
# CORS_ORIGINS=["https://clinica.lionapp.cloud"]
CORS_ORIGINS=https://clinica.lionapp.cloud

BACKEND_PORT=8000
FRONTEND_PORT=80
# En produccion con mismo dominio, dejar vacio (el build usa `/api/v1`).
VITE_API_BASE_URL=

# Sincronización de profesionales desde base externa (MySQL solo lectura)
EXT_DB_ENABLED=true
EXT_DB_ENGINE=mysql
EXT_DB_HOST=clientes.integrandosalud.com
EXT_DB_PORT=36500
EXT_DB_NAME=montegrandedb
EXT_DB_USER=ismontegrande
EXT_DB_PASSWORD=<EXT_DB_PASSWORD>
EXT_DB_CHARSET=utf8mb4
EXT_DB_CONNECT_TIMEOUT=10
# true si el MySQL externo no acepta TLS desde Docker (probar si falla la conexión)
EXT_DB_SSL_DISABLED=false
PROF_SYNC_QUERY=SELECT upe.numero_documento, MAX(upe.nombres) AS nombres, MAX(upe.email) AS email, MAX(upe.profesion) AS profesion, MAX(upe.tipo_matricula) AS tipo_matricula, MAX(upe.numero_matricula) AS numero_matricula, GROUP_CONCAT(DISTINCT upe.especialidad ORDER BY upe.especialidad SEPARATOR ' | ') AS especialidad, 'A' AS estado_usuario FROM montegrande_usuarios_profesiones_especialidades upe WHERE upe.profesion = 'MEDICO' AND upe.matricula_preferida = 'S' AND upe.estado_usuario = 'A' AND upe.usuario_estado_institucion = 'A' AND upe.numero_documento IS NOT NULL AND TRIM(upe.numero_documento) <> '' GROUP BY upe.numero_documento
